{
    "kind": "collectionType",
    "collectionName": "experiences",
    "info": {
        "singularName": "experience",
        "pluralName": "experiences",
        "displayName": "experience"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "cover_image": {
            "type": "media",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "multiple": false,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "short_description": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "destination": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::destination.destination",
            "inversedBy": "experiences"
        },
        "duration": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "group_size": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "description": {
            "type": "blocks",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "program": {
            "type": "blocks",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "audience": {
            "type": "blocks",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "venue_details": {
            "type": "blocks",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "category": {
            "type": "enumeration",
            "required": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "enum": [
                "signature",
                "lab",
                "black"
            ]
        },
        "series": {
            "type": "enumeration",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "enum": [
                "historical",
                "corporate",
                "culinary"
            ]
        },
        "experience_type": {
            "type": "enumeration",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "enum": [
                "game",
                "narrative",
                "performance",
                "team challenge",
                "workshop",
                "cultural",
                "culinary",
                "art",
                "historical"
            ]
        },
        "intent_level": {
            "type": "enumeration",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "enum": [
                "low",
                "medium",
                "high"
            ]
        },
        "cta_text": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "gallery": {
            "type": "media",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "multiple": true,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "seo_title": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "seo_description": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "insights": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::insight.insight",
            "inversedBy": "experiences"
        },
        "inquiries": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::inquiry.inquiry",
            "mappedBy": "experience"
        },
        "ideal_guest": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        }
    }
}
