{
    "kind": "collectionType",
    "collectionName": "destinations",
    "info": {
        "singularName": "destination",
        "pluralName": "destinations",
        "displayName": "destination"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "name": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true,
            "unique": true
        },
        "cover_image": {
            "type": "media",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "multiple": false,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "region": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "short_description": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "intro_text": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "experiences": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::experience.experience",
            "mappedBy": "destination"
        },
        "insights": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::insight.insight",
            "mappedBy": "destination"
        },
        "description": {
            "type": "blocks",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "highlight": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "sections": {
            "type": "component",
            "repeatable": true,
            "component": "destination.section",
            "min": 0,
            "max": 5,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "visibility_status": {
            "type": "enumeration",
            "enum": [
                "active",
                "testing",
                "hidden"
            ],
            "default": "testing",
            "required": true
        },
        "meta_title": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "meta_description": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "order_index": {
            "type": "integer"
        }
    }
}
