{
    "kind": "collectionType",
    "collectionName": "inquiries",
    "info": {
        "singularName": "inquiry",
        "pluralName": "inquiries",
        "displayName": "inquiry"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "name": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "required": true
        },
        "email": {
            "type": "email",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "required": true
        },
        "message": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "required": true
        },
        "experience": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::experience.experience",
            "inversedBy": "inquiries"
        },
        "lead_status": {
            "type": "enumeration",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": "new",
            "enum": [
                "new",
                "contacted",
                "closed"
            ]
        }
    }
}
